{
  "name": "openclaw-memory-smart",
  "version": "1.0.0",
  "private": false,
  "description": "Smart Memory System - 智能记忆系统，支持时间任务、上下文记忆和自适应实体提取",
  "type": "module",
  "main": "./dist/plugin.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./plugin": {
      "import": "./dist/plugin.js",
      "types": "./dist/plugin.d.ts"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/openclaw/memory-smart"
  },
  "keywords": [
    "openclaw",
    "memory",
    "ai",
    "smart-memory",
    "reminder"
  ],
  "author": "luofuliang <1092251982@qq.com>",
  "license": "MIT",
  "peerDependencies": {
    "openclaw": ">=2026.1.26"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.32.0"
  },
  "openclaw": {
    "extensions": [
      "./plugin.ts"
    ]
  }
}
